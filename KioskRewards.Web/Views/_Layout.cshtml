@using System.Globalization
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    // The level-1 ancestor is the site root (the "Home" node) for any page, so the nav is identical everywhere.
    var home = Model.AncestorOrSelf(1);

    // Umbraco sets the ambient thread culture to match the resolved request culture (proven by the
    // Header.* dictionary lookups already working per-culture), so this is the reliable way to know
    // "which language is being rendered right now" outside of a strongly-typed content property.
    var currentCulture = CultureInfo.CurrentUICulture.Name;
}
<!DOCTYPE html>
<html lang="@currentCulture.Split('-')[0]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? Model.Name)</title>
    @if (ViewData["MetaDescription"] is string desc && !string.IsNullOrWhiteSpace(desc))
    {
        <meta name="description" content="@desc" />
    }

    @* ---- Streak visual language: fonts + stylesheet ---------------------- *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@@12..96,400..800&family=Figtree:wght@@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/kioskrewards.css" />
</head>
<body>
    <header class="site">
        @* Two-tone wordmark; the coin logo mark is drawn by .brand::before in CSS *@
        <a class="brand" href="@home.Url()">Kiosk<span>Rewards</span></a>
        <nav>
            <a href="@home.Url()">@home.Name</a>
            @foreach (var child in home.Children().Where(c => c.ContentType.Alias is not ("loginPage" or "memberDashboard")))
            {
                <a href="@child.Url()">@child.Name</a>
            }
            @* .nav-actions (kioskrewards.css) pins this whole group to the far right of the nav row.
               Order matters here: login-status first, lang-switcher LAST, so the lang switcher ends
               up as the true outermost/rightmost element - not "sandwiched" before login-status. *@
            <div class="nav-actions">
                @await Html.PartialAsync("Partials/_LoginStatus")
                <span class="lang-switcher">
                    @foreach (var culture in Model.Cultures.Keys.OrderBy(c => c))
                    {
                        var label = culture.Split('-')[0].ToUpperInvariant();
                        if (string.Equals(culture, currentCulture, StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="lang-current">@label</span>
                        }
                        else
                        {
                            var otherCultureUrl = Model.Url(culture: culture);
                            if (!string.IsNullOrWhiteSpace(otherCultureUrl) && otherCultureUrl != "#")
                            {
                                <a href="@otherCultureUrl">@label</a>
                            }
                        }
                    }
                </span>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site">
        &copy; @DateTime.Now.Year KioskRewards — @Umbraco.GetDictionaryValue("Footer.Tagline")
    </footer>
</body>
</html>
