@using System.Globalization
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    // The level-1 ancestor is the site root (the "Home" node) for any page, so the nav is identical everywhere.
    var home = Model.AncestorOrSelf(1);

    // Umbraco sets the ambient thread culture to match the resolved request culture (proven by the
    // Header.* dictionary lookups already working per-culture), so this is the reliable way to know
    // "which language is being rendered right now" outside of a strongly-typed content property.
    var currentCulture = CultureInfo.CurrentUICulture.Name;
}
<!DOCTYPE html>
<html lang="@currentCulture.Split('-')[0]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? Model.Name)</title>
    @if (ViewData["MetaDescription"] is string desc && !string.IsNullOrWhiteSpace(desc))
    {
        <meta name="description" content="@desc" />
    }
    <style>
        :root { --brand:#1f6feb; --ink:#0d1117; --muted:#57606a; }
        * { box-sizing:border-box; }
        body { margin:0; font-family:system-ui,"Segoe UI",Roboto,sans-serif; color:var(--ink); line-height:1.6; }
        header.site { display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; border-bottom:1px solid #e6e8eb; }
        .brand { font-weight:700; font-size:1.25rem; color:var(--brand); text-decoration:none; }
        nav a { margin-left:1.25rem; color:var(--ink); text-decoration:none; font-weight:500; }
        nav a:hover { color:var(--brand); }
        .member-name { margin-left:1.25rem; color:var(--muted); font-weight:500; }
        nav form { display:inline; }
        .linkbtn { margin-left:.75rem; background:none; border:none; color:var(--brand); font:inherit; font-weight:500; cursor:pointer; padding:0; }
        .linkbtn:hover { text-decoration:underline; }
        main { max-width:820px; margin:0 auto; padding:2.5rem 1.5rem; }
        footer.site { text-align:center; color:var(--muted); padding:2rem; border-top:1px solid #e6e8eb; font-size:.9rem; }
        h1 { font-size:2.25rem; margin:.2em 0 .4em; }
        .balance-card { display:flex; flex-direction:column; gap:.25rem; background:#f6f8fa; border:1px solid #e6e8eb; border-radius:8px; padding:1.25rem 1.5rem; margin:1rem 0 2rem; width:fit-content; }
        .balance-label { color:var(--muted); font-size:.9rem; }
        .balance-value { font-size:2rem; font-weight:700; color:var(--brand); }
        .history-table { width:100%; border-collapse:collapse; }
        .history-table th, .history-table td { text-align:left; padding:.6rem .5rem; border-bottom:1px solid #e6e8eb; }
        .history-table .positive { color:#1a7f37; font-weight:600; }
        .history-table .negative { color:#cf222e; font-weight:600; }
        p.positive { color:#1a7f37; font-weight:600; }
        p.negative { color:#cf222e; font-weight:600; }
        .rewards-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1.25rem; margin-top:1rem; }
        .reward-card { border:1px solid #e6e8eb; border-radius:8px; padding:1.25rem; display:flex; flex-direction:column; gap:.5rem; }
        .reward-card img { width:100%; height:140px; object-fit:cover; border-radius:6px; }
        .reward-cost { font-weight:700; color:var(--brand); margin:0; }
        .reward-card button { margin-top:auto; padding:.5rem 1rem; border:none; border-radius:6px; background:var(--brand); color:#fff; font-weight:600; cursor:pointer; }
        .reward-card button:disabled { background:#c9cdd2; cursor:not-allowed; }
        .lang-switcher { margin-left:1.25rem; }
        .lang-switcher a, .lang-switcher span { margin-left:.4rem; font-weight:600; font-size:.85rem; text-decoration:none; }
        .lang-switcher a { color:var(--muted); }
        .lang-switcher a:hover { color:var(--brand); }
        .lang-switcher span.lang-current { color:var(--brand); }
    </style>
</head>
<body>
    <header class="site">
        <a class="brand" href="@home.Url()">KioskRewards</a>
        <nav>
            <a href="@home.Url()">@home.Name</a>
            @foreach (var child in home.Children().Where(c => c.ContentType.Alias is not ("loginPage" or "memberDashboard")))
            {
                <a href="@child.Url()">@child.Name</a>
            }
            <span class="lang-switcher">
                @foreach (var culture in Model.Cultures.Keys.OrderBy(c => c))
                {
                    var label = culture.Split('-')[0].ToUpperInvariant();
                    if (string.Equals(culture, currentCulture, StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="lang-current">@label</span>
                    }
                    else
                    {
                        var otherCultureUrl = Model.Url(culture: culture);
                        if (!string.IsNullOrWhiteSpace(otherCultureUrl) && otherCultureUrl != "#")
                        {
                            <a href="@otherCultureUrl">@label</a>
                        }
                    }
                }
            </span>
            @await Html.PartialAsync("Partials/_LoginStatus")
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site">
        &copy; @DateTime.Now.Year KioskRewards — @Umbraco.GetDictionaryValue("Footer.Tagline")
    </footer>
</body>
</html>
