@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem<TextBlock>>
@{
    var block = Model.Content;
}
<div class="content-block text-block">
    @if (!string.IsNullOrWhiteSpace(block.Heading))
    {
        <h2>@block.Heading</h2>
    }
    @if (block.Body is not null)
    {
        <div class="body">@block.Body</div>
    }
</div>
