@using KioskRewards.Web.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CompanyReportViewModel>
@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = Model.Name;
    var report = Model.Report;

    // Same "" -> fallback pattern as MemberDashboard.cshtml (gotcha #22): GetDictionaryValue
    // returns "" (not null) for a key that doesn't exist yet in the backoffice, so a plain lookup
    // would silently render blank labels instead of the English fallback.
    string Dict(string key, string fallback)
    {
        var value = Umbraco.GetDictionaryValue(key);
        return string.IsNullOrEmpty(value) ? fallback : value;
    }
}

@* Kiosk Owner-only page (Public Access), scoped to their own account - never another kiosk's data.
   Labels are Dictionary-driven (CompanyReport.* keys). The "Redeemed: X" text inside report.TopRewards
   is NOT a label - it's a frozen string written once into the PointsTransaction ledger at redemption
   time (RewardsController.Redeem) and reused as the reporting group-by key, so it deliberately stays
   whatever it was when each redemption happened (English prefix + whichever culture the reward title
   had at that moment) rather than being re-translated here. *@

<h1>@Model.Name</h1>

<div class="report-stats">
    <div class="report-stat">
        <span class="report-stat-label">@Dict("CompanyReport.TotalEarnedLabel", "Total points earned")</span>
        <span class="report-stat-value">@report.TotalPointsEarned</span>
    </div>
    <div class="report-stat">
        <span class="report-stat-label">@Dict("CompanyReport.TotalRedeemedLabel", "Total points redeemed")</span>
        <span class="report-stat-value">@report.TotalPointsRedeemed</span>
    </div>
    <div class="report-stat">
        <span class="report-stat-label">@Dict("CompanyReport.NetOutstandingLabel", "Net points outstanding")</span>
        <span class="report-stat-value">@report.NetPointsOutstanding</span>
    </div>
</div>

<a class="btn-ghost" href="?format=csv">@Dict("CompanyReport.ExportCsv", "Export CSV")</a>

<h2>@Dict("CompanyReport.TopRewardsHeading", "Top rewards")</h2>
@if (report.TopRewards.Count == 0)
{
    <p>@Dict("CompanyReport.NoRedemptionsYet", "No redemptions yet.")</p>
}
else
{
    <div class="history-wrap">
        <table class="history-table">
            <thead>
                <tr>
                    <th>@Dict("CompanyReport.ColumnReward", "Reward")</th>
                    <th>@Dict("CompanyReport.ColumnRedemptions", "Redemptions")</th>
                    <th>@Dict("CompanyReport.ColumnPointsSpent", "Points spent")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reward in report.TopRewards)
                {
                    <tr>
                        <td>@reward.Description</td>
                        <td>@reward.RedemptionCount</td>
                        <td>@reward.TotalPointsSpent</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
