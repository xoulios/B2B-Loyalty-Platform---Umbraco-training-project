@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HomePage>
@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.MetaTitle) ? Model.Name : Model.MetaTitle;
    ViewData["MetaDescription"] = Model.MetaDescription;
}

<section class="hero">
    <h1>@(string.IsNullOrWhiteSpace(Model.Heading) ? Model.Name : Model.Heading)</h1>
</section>

<div class="body-blocks">
    @await Html.GetBlockListHtmlAsync(Model.BodyBlocks)
</div>
