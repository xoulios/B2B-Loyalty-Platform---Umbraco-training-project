@using KioskRewards.Domain.Enums
@using KioskRewards.Web.Controllers
@using KioskRewards.Web.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<MemberDashboardViewModel>
@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = Model.Name;

    // UmbracoHelper.GetDictionaryValue returns "" (empty string, not null) for a key that doesn't
    // exist yet in the backoffice - so a plain @Umbraco.GetDictionaryValue("Key") call silently
    // renders nothing instead of erroring, which is exactly what made the claim-card heading/label/
    // button look blank before the Dictionary items were created. This local function (a small,
    // reusable block of code defined right here and only usable inside this view) mirrors the same
    // "?? fallback" pattern the controllers already use, just adapted for empty-string instead of null.
    string Dict(string key, string fallback)
    {
        var value = Umbraco.GetDictionaryValue(key);
        return string.IsNullOrEmpty(value) ? fallback : value;
    }
}

<h1>@Model.Name</h1>

<section class="balance-card">
    <span class="balance-label">@Umbraco.GetDictionaryValue("Dashboard.PointsBalanceLabel")</span>
    <span class="balance-value">@Model.Balance</span>
</section>

<section class="claim-card">
    <h2>@Dict("Dashboard.ClaimOrderHeading", "Have an order code?")</h2>

    @if (TempData["ClaimMessage"] is string claimMessage)
    {
        <p class="@(TempData["ClaimSuccess"] as bool? == true ? "positive" : "negative")">@claimMessage</p>
    }

    @using (Html.BeginUmbracoForm<OrderClaimController>(nameof(OrderClaimController.ClaimOrder)))
    {
        <div class="field">
            <label for="code">@Dict("Dashboard.OrderCodeLabel", "Order code")</label>
            <input type="text" id="code" name="code" autocomplete="off" />
        </div>
        <button type="submit" class="btn-primary">@Dict("Dashboard.ClaimButton", "Claim")</button>
    }
</section>

<h2>@Umbraco.GetDictionaryValue("Dashboard.TransactionHistoryHeading")</h2>

@if (Model.History.Count == 0)
{
    <p>@Umbraco.GetDictionaryValue("Dashboard.NoTransactionsYet")</p>
}
else
{
    <div class="history-wrap">
        <table class="history-table">
            <thead>
                <tr>
                    <th>@Umbraco.GetDictionaryValue("Dashboard.ColumnDate")</th>
                    <th>@Umbraco.GetDictionaryValue("Dashboard.ColumnType")</th>
                    <th>@Umbraco.GetDictionaryValue("Dashboard.ColumnDescription")</th>
                    <th>@Umbraco.GetDictionaryValue("Dashboard.ColumnAmount")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in Model.History)
                {
                    var isRedeem = tx.Type == TransactionType.Redeem;
                    <tr>
                        <td>@tx.CreatedUtc.ToLocalTime().ToString("g")</td>
                        <td class="tx-type">
                            <span class="tx-badge @(isRedeem ? "tx-redeem" : "tx-earn")">@Umbraco.GetDictionaryValue(isRedeem ? "Transaction.TypeRedeem" : "Transaction.TypeEarn")</span>
                        </td>
                        <td>@tx.Description</td>
                        <td class="@(isRedeem ? "negative" : "positive")">
                            @(isRedeem ? "-" : "+")@tx.Amount
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
